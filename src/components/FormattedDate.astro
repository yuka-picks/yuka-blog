---
import { getLangFromUrl } from '../i18n/ui';

interface Props {
	date: Date;
}

const { date } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const locale = lang === 'en' ? 'en-US' : 'ja-JP';
---

<time datetime={date.toISOString()}>
	{
		date.toLocaleDateString(locale, {
			year: 'numeric',
			month: 'long',
			day: 'numeric',
		})
	}
</time>
