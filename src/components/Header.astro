---
import { SITE_TITLE } from '../consts';
import { getLangFromUrl, useTranslations } from '../i18n/ui';
import HeaderLink from './HeaderLink.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const base = lang === 'en' ? '/en' : '';
const altHref = lang === 'en' ? '/' : '/en/';
const altLabel = lang === 'en' ? 'JA' : 'EN';
---

<header>
	<nav>
		<h2><a href={`${base}/`}>{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href={`${base}/`}>{t('nav.home')}</HeaderLink>
			<HeaderLink href={`${base}/blog`}>{t('nav.blog')}</HeaderLink>
			<HeaderLink href={`${base}/about`}>{t('nav.about')}</HeaderLink>
		</div>
		<div class="right-links">
			<a href={altHref} class="lang-switch">{altLabel}</a>
			<a href="https://x.com/yuka_picks" target="_blank" class="x-icon">
				<span class="sr-only">X (@yuka_picks)</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="24" height="24"
					><path
						fill="currentColor"
						d="M5.026 15c6.038 0 9.341-5.003 9.341-9.334 0-.14 0-.282-.006-.422A6.685 6.685 0 0 0 16 3.542a6.658 6.658 0 0 1-1.889.518 3.301 3.301 0 0 0 1.447-1.817 6.533 6.533 0 0 1-2.087.793A3.286 3.286 0 0 0 7.875 6.03a9.325 9.325 0 0 1-6.767-3.429 3.289 3.289 0 0 0 1.018 4.382A3.323 3.323 0 0 1 .64 6.575v.045a3.288 3.288 0 0 0 2.632 3.218 3.203 3.203 0 0 1-.865.115 3.23 3.23 0 0 1-.614-.057 3.283 3.283 0 0 0 3.067 2.277A6.588 6.588 0 0 1 .78 13.58a6.32 6.32 0 0 1-.78-.045A9.344 9.344 0 0 0 5.026 15z"
					></path></svg
				>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1.5em;
		background: rgb(var(--surface));
		border-bottom: 1px solid rgb(var(--border));
	}
	h2 {
		margin: 0;
		font-size: 1em;
		letter-spacing: 0.03em;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
		color: var(--accent);
		font-weight: 700;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 960px;
		margin: 0 auto;
	}
	nav a {
		padding: 1.1em 0.6em;
		color: rgb(var(--text-muted));
		border-bottom: 3px solid transparent;
		text-decoration: none;
		font-size: 0.9em;
		transition: color 0.15s;
	}
	nav a:hover {
		color: rgb(var(--text));
		filter: none;
	}
	nav a.active {
		color: rgb(var(--text));
		border-bottom-color: var(--accent);
	}
	.right-links {
		display: flex;
		align-items: center;
	}
	.right-links a {
		display: flex;
		align-items: center;
		color: rgb(var(--text-muted));
		padding: 0.5em;
		transition: color 0.15s;
	}
	.right-links a:hover {
		color: var(--accent);
		filter: none;
	}
	.lang-switch {
		font-size: 0.75em;
		font-weight: 700;
		letter-spacing: 0.06em;
		border: 1px solid rgb(var(--border));
		border-radius: 4px;
		padding: 0.25em 0.55em !important;
		margin-right: 0.3em;
		line-height: 1;
	}
	@media (max-width: 720px) {
		.x-icon {
			display: none;
		}
	}
</style>
