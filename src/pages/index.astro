---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="intro">
				<p class="name">ゆか</p>
				<p class="bio">ギター（Epiphone Casino）・AI・ゲーム。気になったことをXとここに流してます。</p>
				<a href="https://x.com/yuka_picks" target="_blank" class="x-handle">@yuka_picks</a>
			</section>

			{posts.length > 0 && (
				<section class="recent">
					<h2 class="section-title">最近の記事</h2>
					<ul>
						{posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<span class="post-title">{post.data.title}</span>
									<span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
								</a>
							</li>
						))}
					</ul>
					<a href="/blog" class="all-posts">記事をもっと見る →</a>
				</section>
			)}
		</main>
		<Footer />
	</body>
</html>
<style>
	.intro {
		border-left: 3px solid var(--accent);
		padding: 0.5em 0 0.5em 1.2em;
		margin-bottom: 3em;
	}
	.name {
		font-size: 1.8em;
		font-weight: 700;
		color: rgb(var(--text));
		margin: 0 0 0.3em 0;
		line-height: 1;
	}
	.bio {
		color: rgb(var(--text-muted));
		font-size: 1em;
		margin: 0 0 0.8em 0;
		line-height: 1.6;
	}
	.x-handle {
		font-size: 0.9em;
		color: var(--accent);
		text-decoration: none;
	}
	.x-handle:hover {
		text-decoration: underline;
		filter: none;
	}
	.section-title {
		font-size: 0.8em;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: rgb(var(--text-muted));
		margin-bottom: 1em;
		font-weight: 400;
	}
	.recent ul {
		list-style: none;
		padding: 0;
		margin: 0 0 1.5em 0;
	}
	.recent ul li {
		border-bottom: 1px solid rgb(var(--border));
	}
	.recent ul li:first-child {
		border-top: 1px solid rgb(var(--border));
	}
	.recent ul li a {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1em;
		padding: 0.9em 0;
		text-decoration: none;
		color: rgb(var(--text));
		transition: color 0.15s;
	}
	.recent ul li a:hover {
		color: var(--accent);
		filter: none;
	}
	.post-title {
		font-size: 1em;
	}
	.post-date {
		font-size: 0.8em;
		color: rgb(var(--text-muted));
		white-space: nowrap;
		flex-shrink: 0;
	}
	.all-posts {
		font-size: 0.9em;
		color: var(--accent);
		text-decoration: none;
	}
	.all-posts:hover {
		text-decoration: underline;
		filter: none;
	}
</style>
